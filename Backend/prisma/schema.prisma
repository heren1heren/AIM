generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  teacher
  student
}

model User {
  id            Int           @id @default(autoincrement())
  name          String?
  username      String        @unique
  password_hash String
  created_at    DateTime      @default(now())
  admin         Admin?        @relation("AdminUser")
  teacher       Teacher?      @relation("TeacherUser")
  student       Student?      @relation("StudentUser")
  notifications Notification[] @relation("CreatedNotifications")
  messages      Message[]     @relation("SenderMessages") 
  files         File[]        @relation("UploadedFiles")
  profile       UserProfile?  @relation
  conversations Conversation[] @relation("UserConversations") // Many-to-many relation with Conversation
}

model UserProfile {
  id        Int     @id @default(autoincrement())
  user_id   Int     @unique
  nickname  String? // Optional nickname for the user
  avatar    String? // URL for the user's avatar
  bias      String? // Optional bias or preference
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user      User    @relation(fields: [user_id], references: [id]) 
}

model Admin {
  id      Int  @id @default(autoincrement())
  user_id Int  @unique
  user    User @relation("AdminUser", fields: [user_id], references: [id])
  
}

model Teacher {
  id                  Int          @id @default(autoincrement())
  user_id             Int          @unique
  user                User         @relation("TeacherUser", fields: [user_id], references: [id])
  classes             Class[]
  marked_attendances  Attendance[]
}

model Student {
  id      Int     @id @default(autoincrement())
  user_id Int     @unique
  user    User    @relation("StudentUser", fields: [user_id], references: [id])
  class   Class?  @relation(fields: [class_id], references: [id])
  class_id Int?
  submissions Submission[]
  attendances Attendance[]
}

model Class {
  id          Int         @id @default(autoincrement())
  name        String?
  description String?
  teacher_id  Int
  start_date  DateTime     // Start date of the class
  end_date    DateTime     // End date of the class
  created_at  DateTime     @default(now())

  teacher     Teacher      @relation(fields: [teacher_id], references: [id])
  students    Student[]
  assignments Assignment[]
  notification Notification[] // Relation to Notification
  files       File[]
  attendances Attendance[]
  contents    Content[]    // Relation to Content
}

model Assignment {
  id          Int        @id @default(autoincrement())
  class_id    Int
  title       String?
  description String?
  due_date    DateTime?
  assignedDate DateTime   // Date when the assignment is assigned
  created_at  DateTime    @default(now())
  class       Class       @relation(fields: [class_id], references: [id])
  submissions Submission[]
  files       File[]
}

model Submission {
  id           Int        @id @default(autoincrement())
  assignment_id Int
  student_id   Int
  content      String?
  submitted_at DateTime   @default(now())
  grade        Int?
  feedback     String?
  assignment   Assignment @relation(fields: [assignment_id], references: [id])
  student      Student    @relation(fields: [student_id], references: [id])
  files        File[]
}

model Notification {
  id              Int         @id @default(autoincrement())
  title           String?
  message         String?
  created_by      Int
  created_at      DateTime    @default(now())
  class_id        Int?        
  is_for_students Boolean      @default(false) 
  is_for_teachers Boolean      @default(false) 
  is_global       Boolean      @default(false) 

  creator         User        @relation("CreatedNotifications", fields: [created_by], references: [id])
  class           Class?      @relation(fields: [class_id], references: [id]) // Relation to Class
  files           File[]      // Relation to File model
}

enum ConversationType {
  private
  group
  class
}
model Conversation {
  id             Int                     @id @default(autoincrement())
  created_at     DateTime                @default(now())
  type           ConversationType        @default(group) // Enum for conversation type
  users          User[]                  @relation("UserConversations") // Many-to-many relation with User
  messages       Message[]               // Relation to messages
}

model Message {
  id             Int          @id @default(autoincrement())
  conversation_id Int
  sender_id      Int
  content        String?
  created_at     DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversation_id], references: [id]) // Relation to Conversation
  sender         User         @relation("SenderMessages", fields: [sender_id], references: [id]) // Relation to User
}



model File {
  id             Int          @id @default(autoincrement())
  url            String
  filename       String?
  mimetype       String?
  size           Int?
  uploaded_by    Int
  created_at     DateTime     @default(now())
  submission_id  Int?
  assignment_id  Int?
  class_id       Int?
  notification_id Int?
  content_id     Int?

  uploader       User         @relation("UploadedFiles", fields: [uploaded_by], references: [id])
  submission     Submission?  @relation(fields: [submission_id], references: [id])
  assignment     Assignment?  @relation(fields: [assignment_id], references: [id])
  class          Class?       @relation(fields: [class_id], references: [id])
  notification   Notification? @relation(fields: [notification_id], references: [id]) // Relation to Notification
  content        Content?     @relation(fields: [content_id], references: [id])
}

model Attendance {
  id          Int      @id @default(autoincrement())
  student_id  Int      
  class_id    Int      
  date        DateTime 
  status      AttendanceStatus @default(PRESENT) 
  comment     String? 
  reason      String?
  marked_by   Int?   
  created_at  DateTime @default(now())

  student     Student  @relation(fields: [student_id], references: [id])
  class       Class    @relation(fields: [class_id], references: [id])
  marker      Teacher? @relation(fields: [marked_by], references: [id])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model Content {
  id          Int      @id @default(autoincrement())
  title       String   // Title of the content
  description String?  // Optional description of the content
  urls        String[] // Array of URLs for external resources
  class_id    Int      // Foreign key to the Class model

  assignedDate DateTime // Date when the content is assigned
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  class       Class    @relation(fields: [class_id], references: [id]) // Relation to Class
  files       File[]   // Relation to File model
}