generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("LOCAL_DATABASE_URL")
}


model User {
  id            Int           @id @default(autoincrement())
  name          String?
  username      String        @unique
  password_hash String
  created_at    DateTime      @default(now())
  updated_at    DateTime?     @updatedAt
  bio           String?

  avatarKey     String?

  admin         Admin?        @relation("AdminUser")
  teacher       Teacher?      @relation("TeacherUser")
  student       Student?      @relation("StudentUser")

  // Notifications created by the user
  createdNotifications Notification[] @relation("CreatedNotifications")

  // Notifications received by the user
  recipientNotifications Notification[] @relation("RecipientNotifications")

  // Notifications read by the user
  readNotifications Notification[] @relation("ReadNotifications")

  messages      Message[]     @relation("SenderMessages") 
  received_messages  Message[] @relation("RecipientMessages")
  files         File[]        @relation("UploadedFiles")
  conversations Conversation[] @relation("UserConversations")
}

model Admin {
  id      Int  @id @default(autoincrement())
  user_id Int  @unique
  user    User @relation("AdminUser", fields: [user_id], references: [id])
}

model Teacher {
  id                  Int          @id @default(autoincrement())
  user_id             Int          @unique
  user                User         @relation("TeacherUser", fields: [user_id], references: [id])
  classes             Class[]
  marked_attendances  Attendance[]
}

model Student {
  id      Int     @id @default(autoincrement())
  user_id Int     @unique
  user    User    @relation("StudentUser", fields: [user_id], references: [id])
  class   Class?  @relation(fields: [class_id], references: [id])
  class_id Int?
  submissions Submission[]
  attendances Attendance[]
}

model Class {
  id          Int         @id @default(autoincrement())
  name        String?
  description String?
  teacher_id  Int
  start_date  DateTime     // Start date of the class
  end_date    DateTime     // End date of the class
  created_at  DateTime     @default(now())

  teacher     Teacher      @relation(fields: [teacher_id], references: [id])
  students    Student[]
  assignments Assignment[]
  notifications Notification[] @relation("ClassNotifications") // Updated relation
  files       File[]
  attendances Attendance[]
  contents    Content[]    // Relation to Content
}

model Assignment {
  id          Int        @id @default(autoincrement())
  class_id    Int
  title       String?
  description String?
  due_date    DateTime?
  assignedDate DateTime   // Date when the assignment is assigned
  created_at  DateTime    @default(now())
  class       Class       @relation(fields: [class_id], references: [id])
  submissions Submission[]
  files       File[]
}

model Submission {
  id           Int        @id @default(autoincrement())
  assignment_id Int
  student_id   Int
  content      String?
  submitted_at DateTime   @default(now())
  grade        Int?
  feedback     String?
  assignment   Assignment @relation(fields: [assignment_id], references: [id])
  student      Student    @relation(fields: [student_id], references: [id])
  files        File[]
}

model Notification {
  id              Int         @id @default(autoincrement())
  title           String?
  message         String?
  created_by      Int
  created_at      DateTime    @default(now())
  is_for_students Boolean      @default(false) 
  is_for_teachers Boolean      @default(false) 
  is_global       Boolean      @default(false) 

  // Relation to the creator of the notification
  creator         User        @relation("CreatedNotifications", fields: [created_by], references: [id])

  // Relation to the recipients of the notification
  recipients      User[]      @relation("RecipientNotifications")

  // Many-to-many relation with Class
  classes         Class[]     @relation("ClassNotifications")

  // Relation to the users who have read the notification
  read_users      User[]      @relation("ReadNotifications")

  files           File[]      // Relation to File model
}

enum ConversationType {
  private
  group
  class
}
model Conversation {
  id             Int                     @id @default(autoincrement())
  created_at     DateTime                @default(now())
  type           ConversationType        @default(group) // Enum for conversation type
  users          User[]                  @relation("UserConversations") // Many-to-many relation with User
  messages       Message[]               // Relation to messages
}

model Message {
  id             Int          @id @default(autoincrement())
  conversation_id Int
  sender_id      Int
  recipient_id   Int?
  content        String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt // Automatically updates on modification
  conversation   Conversation @relation(fields: [conversation_id], references: [id]) // Relation to Conversation
  sender         User         @relation("SenderMessages", fields: [sender_id], references: [id]) // Relation to User
  recipient      User?        @relation("RecipientMessages", fields: [recipient_id], references: [id])
}

model File {
  id             Int          @id @default(autoincrement())
  key            String       
  filename       String?
  mimetype       String?
  size           Int?
  uploaded_by    Int
  created_at     DateTime     @default(now())
  submission_id  Int?
  assignment_id  Int?
  class_id       Int?
  notification_id Int?
  content_id     Int?

  uploader       User         @relation("UploadedFiles", fields: [uploaded_by], references: [id])
  submission     Submission?  @relation(fields: [submission_id], references: [id])
  assignment     Assignment?  @relation(fields: [assignment_id], references: [id])
  class          Class?       @relation(fields: [class_id], references: [id])
  notification   Notification? @relation(fields: [notification_id], references: [id])
  content        Content?     @relation(fields: [content_id], references: [id])

 
}

model Attendance {
  id          Int      @id @default(autoincrement())
  student_id  Int      
  class_id    Int      
  date        DateTime 
  status      AttendanceStatus @default(PRESENT) 
  comment     String? 
  reason      String?
  marked_by   Int?   
  created_at  DateTime @default(now())

  student     Student  @relation(fields: [student_id], references: [id])
  class       Class    @relation(fields: [class_id], references: [id])
  marker      Teacher? @relation(fields: [marked_by], references: [id])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model Content {
  id          Int      @id @default(autoincrement())
  title       String   // Title of the content
  description String?  // Optional description of the content
  urls        String[] // Array of URLs for external resources
  class_id    Int      // Foreign key to the Class model

  assignedDate DateTime // Date when the content is assigned
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  class       Class    @relation(fields: [class_id], references: [id]) // Relation to Class
  files       File[]   // Relation to File model
}